---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-bg-page: oklch(0.982 0.006 170);
    --aw-color-bg-page-dark: oklch(0.17 0.014 175);
    --aw-color-surface: oklch(0.998 0.002 170);
    --aw-color-surface-muted: oklch(0.955 0.014 165);
    --aw-color-border: oklch(0.875 0.018 165);

    --aw-color-primary: oklch(0.405 0.105 158);
    --aw-color-secondary: oklch(0.315 0.072 162);
    --aw-color-accent: oklch(0.655 0.145 142);

    --aw-color-text-heading: oklch(0.185 0.018 245);
    --aw-color-text-default: oklch(0.27 0.02 238);
    --aw-color-text-muted: oklch(0.425 0.018 225);

    --aw-color-success: oklch(0.55 0.13 145);
    --aw-color-warning: oklch(0.68 0.12 78);
    --aw-color-danger: oklch(0.54 0.17 25);

    ::selection {
      background-color: oklch(0.845 0.075 150);
      color: oklch(0.16 0.02 238);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-bg-page: oklch(0.17 0.014 175);
    --aw-color-bg-page-dark: oklch(0.17 0.014 175);
    --aw-color-surface: oklch(0.215 0.016 172);
    --aw-color-surface-muted: oklch(0.265 0.018 168);
    --aw-color-border: oklch(0.36 0.02 165);

    --aw-color-primary: oklch(0.745 0.118 153);
    --aw-color-secondary: oklch(0.66 0.09 158);
    --aw-color-accent: oklch(0.78 0.125 138);

    --aw-color-text-heading: oklch(0.975 0.006 230);
    --aw-color-text-default: oklch(0.92 0.01 230);
    --aw-color-text-muted: oklch(0.765 0.018 215);

    --aw-color-success: oklch(0.72 0.105 145);
    --aw-color-warning: oklch(0.8 0.1 82);
    --aw-color-danger: oklch(0.68 0.16 25);

    ::selection {
      background-color: oklch(0.37 0.082 150);
      color: oklch(0.985 0.006 230);
    }
  }
</style>
