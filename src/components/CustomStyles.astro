---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-bg-page: oklch(0.986 0.004 168);
    --aw-color-bg-page-dark: oklch(0.152 0.012 172);
    --aw-color-surface: oklch(0.997 0.002 168);
    --aw-color-surface-muted: oklch(0.958 0.009 166);
    --aw-color-border: oklch(0.872 0.012 166);

    --aw-color-primary: oklch(0.392 0.102 158);
    --aw-color-secondary: oklch(0.305 0.068 162);
    --aw-color-accent: oklch(0.59 0.105 145);

    --aw-color-text-heading: oklch(0.19 0.016 230);
    --aw-color-text-default: oklch(0.295 0.018 224);
    --aw-color-text-muted: oklch(0.44 0.016 216);

    --aw-color-success: oklch(0.55 0.13 145);
    --aw-color-warning: oklch(0.68 0.12 78);
    --aw-color-danger: oklch(0.54 0.17 25);

    ::selection {
      background-color: oklch(0.845 0.075 150);
      color: oklch(0.16 0.02 238);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-bg-page: oklch(0.152 0.012 172);
    --aw-color-bg-page-dark: oklch(0.152 0.012 172);
    --aw-color-surface: oklch(0.19 0.013 172);
    --aw-color-surface-muted: oklch(0.232 0.016 168);
    --aw-color-border: oklch(0.34 0.018 166);

    --aw-color-primary: oklch(0.62 0.088 153);
    --aw-color-secondary: oklch(0.43 0.066 158);
    --aw-color-accent: oklch(0.64 0.078 142);

    --aw-color-text-heading: oklch(0.965 0.006 220);
    --aw-color-text-default: oklch(0.9 0.01 218);
    --aw-color-text-muted: oklch(0.735 0.014 212);

    --aw-color-success: oklch(0.72 0.105 145);
    --aw-color-warning: oklch(0.8 0.1 82);
    --aw-color-danger: oklch(0.68 0.16 25);

    ::selection {
      background-color: oklch(0.37 0.082 150);
      color: oklch(0.985 0.006 230);
    }
  }
</style>
