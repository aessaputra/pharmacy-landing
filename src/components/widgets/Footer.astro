---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';
import sinarFarmaLogo from '~/assets/images/sinar-farma-sf-02-squircle.svg';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer
  class:list={[
    { dark: theme === 'dark' },
    'relative border-t border-black/5 dark:border-white/10 bg-white/50 dark:bg-slate-900/50 backdrop-blur-lg',
  ]}
>
  <div class="relative max-w-7xl mx-auto px-6 py-12 sm:px-8 md:py-16">
    <div class="flex flex-col lg:flex-row justify-between gap-12 lg:gap-16">
      <!-- Brand & Navigation (Left Side) -->
      <div class="flex flex-col gap-10 lg:w-1/3 shrink-0">
        <!-- Brand -->
        <div>
          <a
            class="inline-flex items-center gap-3 font-heading text-2xl font-bold tracking-tight text-heading mb-4 transition-transform hover:scale-105 origin-left"
            href={getHomePermalink()}
          >
            <img src={sinarFarmaLogo.src} alt={SITE?.name} class="h-10 w-auto rounded-xl shadow-sm" />
            {SITE?.name}
          </a>
          {
            footNote && (
              <div class="text-base text-muted dark:text-slate-400 leading-relaxed">
                <Fragment set:html={footNote} />
              </div>
            )
          }
        </div>

        <!-- Navigation Links -->
        <div class="flex flex-wrap gap-8 sm:gap-16">
          {
            links.map(({ title, links }) => (
              <div>
                <div class="font-heading font-semibold text-heading mb-4 text-lg">{title}</div>
                {links && Array.isArray(links) && links.length > 0 && (
                  <ul class="flex flex-col gap-3">
                    {links.map(({ text, href, ariaLabel }) => (
                      <li>
                        <a
                          class="text-muted hover:text-primary dark:text-slate-400 dark:hover:text-primary transition-colors duration-300 font-medium"
                          href={href}
                          aria-label={ariaLabel}
                        >
                          <Fragment set:html={text} />
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            ))
          }
        </div>
      </div>

      <!-- Map Section (Right Side) -->
      <div class="lg:w-2/3 flex flex-col">
        <h3 class="font-heading font-semibold text-heading mb-4 text-lg">Kunjungi Apotek Kami</h3>
        <div
          class="w-full h-[250px] sm:h-[350px] lg:h-full min-h-[300px] rounded-[1.5rem] overflow-hidden bg-gray-100 dark:bg-gray-800 shadow-inner ring-1 ring-black/5 dark:ring-white/10 group relative"
        >
          <div
            class="absolute inset-0 bg-primary/5 group-hover:bg-transparent transition-colors duration-500 pointer-events-none z-10"
          >
          </div>
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d507758.7462016947!2d105.64864067343748!3d-6.148799300000003!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e41f500649b77e7%3A0x23eae1839966fdf8!2sApotek%20Sinar%20Farma!5e0!3m2!1sen!2sid!4v1782051943270!5m2!1sen!2sid"
            class="w-full h-full border-0 grayscale-[30%] contrast-125 opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>

    <!-- Bottom Section (Copyright & Socials) -->
    <div
      class="mt-12 pt-8 border-t border-black/5 dark:border-white/10 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <div class="text-sm text-muted dark:text-slate-500">
        &copy; {new Date().getFullYear()}
        {SITE?.name}. Hak Cipta Dilindungi.
      </div>

      {
        socialLinks?.length ? (
          <ul class="flex gap-2">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="text-muted hover:text-primary hover:bg-primary/5 dark:text-slate-400 dark:hover:bg-primary/10 rounded-xl p-2.5 inline-flex items-center transition-all duration-300"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  {!icon && <Fragment set:html={text} />}
                </a>
              </li>
            ))}
          </ul>
        ) : null
      }
    </div>
  </div>
</footer>
