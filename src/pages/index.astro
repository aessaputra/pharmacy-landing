---
import Layout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Sinar Farma — Aplikasi Apotek',
  description:
    'Landing page aplikasi Sinar Farma untuk mengenal kebutuhan apotek harian secara ringkas, jelas, dan aman.',
  ignoreTitleTemplate: true,
};

const values = [
  {
    title: 'Terpercaya',
    note: 'Bahasa dibatasi pada informasi umum yang mudah dicek kembali.',
  },
  {
    title: 'Ramah',
    note: 'Susunan pendek membantu pengunjung membaca tanpa istilah rumit.',
  },
  {
    title: 'Cepat',
    note: 'Ringkasan dan arahan resmi disusun untuk layar ponsel.',
  },
];

const steps = [
  {
    title: 'Cari kebutuhan',
    note: 'Mulai dari ringkasan umum tentang kebutuhan apotek harian yang tersedia di halaman ini.',
  },
  {
    title: 'Baca ringkasan',
    note: 'Gunakan teks singkat untuk memahami fungsi dasar aplikasi sebelum mengikuti arahan berikutnya.',
  },
  {
    title: 'Ikuti info resmi',
    note: 'Saat kanal aplikasi diumumkan, bagian download akan menjadi titik awal yang aman.',
  },
];

const faqs = [
  {
    question: 'Apakah tautan aplikasi sudah tersedia?',
    answer: 'Belum. Halaman ini menyiapkan tempat informasi resmi tanpa menambahkan tautan yang belum diverifikasi.',
  },
  {
    question: 'Apa yang bisa dilihat di halaman ini?',
    answer: 'Pengunjung dapat membaca gambaran aplikasi, cara memakai informasi, dan status download.',
  },
];
---

<Layout metadata={metadata}>
  <section id="beranda" class="relative overflow-hidden scroll-mt-[72px]">
    <div class="absolute inset-x-0 top-0 -z-10 h-64 bg-primary/8 dark:bg-primary/10" aria-hidden="true"></div>
    <div class="absolute left-1/2 top-18 -z-10 h-72 w-72 -translate-x-1/2 rounded-full bg-accent/14 blur-3xl" aria-hidden="true"></div>
    <div
      class="mx-auto grid max-w-7xl gap-10 px-4 pb-12 pt-8 sm:px-6 md:pb-16 md:pt-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(18rem,0.52fr)] lg:items-start lg:gap-12 lg:pb-20 lg:pt-14"
    >
      <div class="max-w-3xl">
        <p
          class="mb-5 inline-flex rounded-full bg-[var(--aw-color-surface)] px-4 py-2 text-sm font-semibold text-secondary ring-1 ring-primary/20 dark:text-primary"
        >
          Sinar Farma
        </p>
        <h1
          class="font-heading text-4xl font-bold leading-tight tracking-[-0.025em] text-heading text-balance sm:text-5xl lg:text-6xl"
        >
          Aplikasi apotek untuk kebutuhan harian.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-muted text-pretty dark:text-[var(--aw-color-text-default)]">
          Sinar Farma membantu pengunjung memahami kebutuhan apotek harian lewat tampilan ponsel yang ringkas. Halaman
          ini menjaga informasi tetap umum sampai detail resmi tersedia.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button
            variant="primary"
            text="Download aplikasi"
            href="#download"
            class="focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
          />
          <Button
            variant="secondary"
            text="Fitur"
            href="#fitur"
            class="focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
          />
        </div>
      </div>

      <aside aria-label="Pratinjau aplikasi Sinar Farma" class="mx-auto w-full max-w-[18rem] lg:mr-0 lg:max-w-[19rem]">
        <div class="relative rounded-2xl bg-primary/8 p-2.5 ring-1 ring-primary/15 dark:bg-primary/10">
          <div class="absolute -right-8 top-10 -z-10 h-32 w-32 rounded-full bg-accent/20 blur-3xl" aria-hidden="true">
          </div>
          <div class="absolute -bottom-6 -left-8 -z-10 h-36 w-36 rounded-full bg-primary/15 blur-3xl" aria-hidden="true">
          </div>
          <div class="overflow-hidden rounded-xl bg-[var(--aw-color-surface)] ring-1 ring-primary/10">
            <Image
              src="~/assets/images/app.png"
              alt="Tampilan aplikasi Sinar Farma untuk mencari kebutuhan apotek harian."
              width={442}
              height={862}
              widths={[280, 320, 384, 442]}
              sizes="(min-width: 1024px) 19rem, min(88vw, 18rem)"
              format="webp"
              layout="responsive"
              loading="eager"
              fetchpriority="high"
              class="block h-auto max-h-[34rem] w-full object-contain sm:max-h-[38rem] lg:max-h-[40rem]"
            />
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section aria-labelledby="nilai-heading" class="bg-[var(--aw-color-surface)]">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-22">
      <div class="max-w-2xl">
        <h2
          id="nilai-heading"
          class="font-heading text-3xl font-bold tracking-[-0.02em] text-heading text-balance md:text-4xl"
        >
          Dibuat untuk membaca cepat.
        </h2>
        <p class="mt-4 text-lg leading-8 text-muted text-pretty dark:text-[var(--aw-color-text-default)]">
          Nilai halaman dijaga sederhana: jelas, dekat dengan kebutuhan umum, dan tidak melampaui informasi resmi.
        </p>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-[1fr_0.88fr_1.12fr]">
        {
          values.map((value) => (
            <article class="rounded-xl border border-primary/15 bg-[var(--aw-color-surface-muted)] p-5">
              <h3 class="font-heading text-xl font-bold tracking-[-0.015em] text-heading">{value.title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted dark:text-[var(--aw-color-text-default)]">{value.note}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="fitur" class="scroll-mt-[72px] bg-[var(--aw-color-surface-muted)]">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 md:py-16">
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <div>
          <h2 class="font-heading text-3xl font-bold tracking-[-0.02em] text-heading text-balance md:text-4xl">
            Fitur ringkas.
          </h2>
          <p class="mt-4 max-w-xl text-lg leading-8 text-muted text-pretty dark:text-[var(--aw-color-text-default)]">
            Bagian ini menampilkan fitur utama yang membantu pengunjung memahami aplikasi Sinar Farma.
          </p>
        </div>

        <ol class="space-y-3">
          {
            steps.map((step, index) => (
              <li class="rounded-xl bg-[var(--aw-color-surface)] p-5 ring-1 ring-primary/10">
                <div class="flex gap-4">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-secondary dark:text-primary">
                    {index + 1}
                  </span>
                  <div>
                    <h3 class="font-semibold text-heading">{step.title}</h3>
                    <p class="mt-1 text-sm leading-6 text-muted dark:text-[var(--aw-color-text-default)]">
                      {step.note}
                    </p>
                  </div>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <section id="tentang" class="scroll-mt-[72px]">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-14 sm:px-6 md:grid-cols-[0.82fr_1.18fr] md:py-20">
      <h2 class="font-heading text-3xl font-bold tracking-[-0.02em] text-heading text-balance md:text-4xl">
        Tentang Sinar Farma.
      </h2>
      <div class="max-w-3xl text-lg leading-8 text-muted text-pretty dark:text-[var(--aw-color-text-default)]">
        <p>
          Sinar Farma adalah halaman pengantar aplikasi apotek untuk kebutuhan umum. Konten dibuat singkat agar
          pengunjung dapat memahami arah aplikasi sebelum mengikuti informasi resmi berikutnya.
        </p>
      </div>
    </div>
  </section>

  <section aria-labelledby="aman-heading" class="bg-[var(--aw-color-surface)]">
    <div class="mx-auto max-w-7xl px-4 pb-14 sm:px-6 md:pb-20">
      <div class="rounded-2xl border border-primary/15 bg-[var(--aw-color-surface-muted)] p-6 md:p-8">
        <h2
          id="aman-heading"
          class="font-heading text-3xl font-bold tracking-[-0.02em] text-heading text-balance md:text-4xl"
        >
          Batas informasi dijaga.
        </h2>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-muted text-pretty dark:text-[var(--aw-color-text-default)]">
          Halaman ini hanya memakai informasi umum dan status yang aman ditampilkan. Detail resmi dapat ditambahkan
          setelah sumber Sinar Farma tersedia.
        </p>
      </div>
    </div>
  </section>

  <section aria-labelledby="faq-heading" class="bg-[var(--aw-color-surface-muted)]">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 md:py-16">
      <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
        <div>
          <h2
            id="faq-heading"
            class="font-heading text-3xl font-bold tracking-[-0.02em] text-heading text-balance md:text-4xl"
          >
            Pertanyaan singkat.
          </h2>
          <p class="mt-4 max-w-xl text-lg leading-8 text-muted text-pretty dark:text-[var(--aw-color-text-default)]">
            Jawaban tetap ringkas agar tidak menambah janji yang belum terverifikasi.
          </p>
        </div>
        <div class="space-y-3">
          {
            faqs.map((faq) => (
              <article class="rounded-xl bg-[var(--aw-color-surface)] p-5 ring-1 ring-primary/10">
                <h3 class="font-semibold text-heading">{faq.question}</h3>
                <p class="mt-2 text-sm leading-6 text-muted dark:text-[var(--aw-color-text-default)]">{faq.answer}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="download" class="scroll-mt-[72px] px-4 py-16 sm:px-6 md:py-24">
    <div class="mx-auto max-w-7xl rounded-2xl bg-primary px-6 py-10 text-white md:px-10 md:py-12">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
        <div class="max-w-2xl">
          <h2 class="font-heading text-3xl font-bold tracking-[-0.02em] text-balance md:text-4xl">
            Download aplikasi saat rilis resmi tersedia.
          </h2>
          <p class="mt-4 text-lg leading-8 text-white/90 text-pretty">
            Bagian ini disiapkan sebagai titik status. Tautan resmi akan ditampilkan setelah informasi Sinar Farma
            tersedia.
          </p>
          <p class="mt-3 text-sm leading-6 text-white/80">Status: menunggu pengumuman resmi Sinar Farma.</p>
        </div>
        <Button
          variant="secondary"
          text="Kembali ke atas"
          href="#beranda"
          class="border-white bg-white text-secondary hover:border-white hover:bg-white/90 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white dark:border-white dark:bg-white dark:text-secondary"
        />
      </div>
    </div>
  </section>
</Layout>
