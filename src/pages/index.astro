---
import Layout from '~/layouts/PageLayout.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: 'Sinar Farma — Profil Apotek',
  description:
    'Profil singkat Sinar Farma untuk mengenal obat bebas, vitamin & suplemen, alat kesehatan, dan kebutuhan kesehatan harian.',
  ignoreTitleTemplate: true,
};

const categories = [
  {
    title: 'Obat bebas',
    note: 'Kategori umum untuk kebutuhan apotek sehari-hari.',
  },
  {
    title: 'Vitamin & suplemen',
    note: 'Kebutuhan penunjang rutinitas harian.',
  },
  {
    title: 'Alat kesehatan',
    note: 'Perlengkapan kesehatan dasar.',
  },
  {
    title: 'Kebutuhan harian',
    note: 'Perawatan praktis untuk keseharian.',
  },
];

const values = [
  {
    title: 'Terpercaya',
    note: 'Informasi disusun hati-hati.',
  },
  {
    title: 'Ramah',
    note: 'Bahasa dibuat tenang dan mudah dipahami.',
  },
  {
    title: 'Cepat',
    note: 'Isi halaman singkat agar mudah dipindai.',
  },
];
---

<Layout metadata={metadata}>
  <section id="beranda" class="relative overflow-hidden scroll-mt-[72px]">
    <div
      class="mx-auto grid max-w-7xl gap-12 px-4 py-16 sm:px-6 md:py-24 lg:grid-cols-[0.92fr_1.08fr] lg:items-center lg:py-28"
    >
      <div class="max-w-3xl">
        <p
          class="mb-5 inline-flex rounded-full bg-primary/10 px-4 py-2 text-sm font-semibold text-secondary dark:text-primary"
        >
          Sinar Farma
        </p>
        <h1
          class="font-heading text-4xl font-bold leading-tight tracking-[-0.025em] text-heading text-balance sm:text-5xl lg:text-6xl"
        >
          Profil apotek untuk kebutuhan kesehatan harian.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-muted text-pretty dark:text-slate-300">
          Kenali Sinar Farma melalui ringkasan kategori umum yang mudah dipindai. Detail kontak resmi akan ditampilkan
          melalui kanal resmi saat tersedia.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button variant="primary" text="Lihat informasi kontak" href="#kontak" />
          <Button variant="secondary" text="Lihat rak kebutuhan" href="#kategori" />
        </div>
      </div>

      <div
        id="kategori"
        class="scroll-mt-[72px] rounded-2xl bg-[var(--aw-color-surface-muted)] p-3 dark:bg-[var(--aw-color-surface-muted)]"
      >
        <div class="rounded-xl bg-[var(--aw-color-surface)] p-5 ring-1 ring-primary/15 md:p-6">
          <div class="flex flex-col gap-3 border-b border-primary/15 pb-5 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 class="font-heading text-2xl font-bold tracking-[-0.02em] text-heading text-balance md:text-3xl">
                Rak kebutuhan Sinar Farma.
              </h2>
              <p class="mt-2 max-w-xl text-sm leading-6 text-muted dark:text-slate-300">
                Satu ringkasan untuk mengenal kelompok kebutuhan umum, tanpa klaim stok atau transaksi.
              </p>
            </div>
            <span
              class="w-fit rounded-full bg-accent/15 px-3 py-1 text-sm font-semibold text-secondary dark:text-primary"
            >
              ringkas
            </span>
          </div>

          <div class="mt-5 space-y-2">
            {
              categories.map((category) => (
                <article class="grid gap-3 rounded-lg bg-page px-4 py-3 ring-1 ring-primary/10 sm:grid-cols-[minmax(9rem,0.8fr)_1.2fr] sm:items-center dark:bg-[var(--aw-color-surface-muted)]">
                  <div class="flex items-center gap-3">
                    <span class="h-2.5 w-8 rounded-full bg-primary" aria-hidden="true" />
                    <h3 class="font-semibold text-heading">{category.title}</h3>
                  </div>
                  <p class="text-sm leading-6 text-muted dark:text-slate-300">{category.note}</p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <section aria-label="Nilai pengalaman" class="border-y border-primary/15 bg-[var(--aw-color-surface-muted)]">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 md:py-10">
      <div
        class="flex flex-col gap-5 rounded-2xl bg-[var(--aw-color-surface)] p-5 ring-1 ring-primary/10 md:flex-row md:items-center md:justify-between md:p-6"
      >
        <p class="max-w-sm text-sm font-semibold leading-6 text-secondary dark:text-primary">
          Cara halaman ini membantu pengunjung: jelas, ramah, dan cepat dipindai.
        </p>
        <div class="grid gap-4 md:grid-cols-3 md:gap-6">
          {
            values.map((value) => (
              <div class="flex gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-accent" aria-hidden="true" />
                <div>
                  <h3 class="font-semibold text-heading">{value.title}</h3>
                  <p class="mt-1 text-sm leading-6 text-muted dark:text-slate-300">{value.note}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="tentang" class="scroll-mt-[72px]">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 sm:px-6 md:grid-cols-[0.8fr_1.2fr] md:py-20">
      <h2 class="font-heading text-3xl font-bold tracking-[-0.02em] text-heading text-balance md:text-4xl">
        Tentang Sinar Farma.
      </h2>
      <div class="max-w-3xl text-lg leading-8 text-muted text-pretty dark:text-slate-300">
        <p>
          Sinar Farma adalah profil apotek untuk mengenalkan kebutuhan kesehatan umum secara singkat. Halaman ini
          membantu pengunjung memahami arah informasi sebelum menggunakan kanal resmi.
        </p>
      </div>
    </div>
  </section>

  <section id="kontak" class="scroll-mt-[72px] px-4 pb-16 sm:px-6 md:pb-24">
    <div class="mx-auto max-w-7xl rounded-2xl bg-primary px-6 py-10 text-white md:px-10 md:py-12">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
        <div class="max-w-2xl">
          <h2 class="font-heading text-3xl font-bold tracking-[-0.02em] text-balance md:text-4xl">
            Informasi kontak resmi akan ditampilkan di sini.
          </h2>
          <p class="mt-4 text-lg leading-8 text-white/90 text-pretty">
            Gunakan hanya kanal resmi Sinar Farma saat tersedia. Halaman ini tidak menampilkan nomor, alamat, atau
            tautan yang belum terverifikasi.
          </p>
        </div>
        <Button
          variant="secondary"
          text="Kembali ke rak kebutuhan"
          href="#kategori"
          class="border-white bg-white text-secondary hover:border-white hover:bg-white/90 dark:border-white dark:bg-white dark:text-secondary"
        />
      </div>
    </div>
  </section>
</Layout>
